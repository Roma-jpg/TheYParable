[node name="Label2" type="Label" parent="SlideContainer/Content" index="4"]
modulate = Color(1, 1, 1, 0)
layout_mode = 2
size_flags_vertical = 10
text = "Текстуры - это растровые изображения, несущие информацию о внешнем виде поверхности: цвет (albedo), рельеф (normal map), шероховатость (roughness) и другие детали. Материал — это шейдерный набор параметров и инструкций, определяющих физические свойства поверхности (металличность, прозрачность, преломление) и её реакцию на источники света. Материал использует текстуры как входные данные (слоты), комбинируя их с настройками освещения, чтобы для каждого пикселя модели вычислить итоговый цвет на экране. Таким образом, текстуры предоставляют детализацию, а материал управляет тем, как эти детали взаимодействуют со светом в игровой среде."
autowrap_mode = 3

[node name="AnimationPlayer" parent="." index="2"]
libraries = {
&"": SubResource("AnimationLibrary_cghbj")
}
