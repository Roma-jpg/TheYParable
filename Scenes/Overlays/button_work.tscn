[node name="Label2" type="Label" parent="SlideContainer/Content" index="3"]
modulate = Color(1, 1, 1, 0)
layout_mode = 2
size_flags_vertical = 8
text = "Вот как работает кнопка в игре: когда игрок ставит кубик на кнопку (или встаёт сам), кубик попадает в специальную невидимую зону под названием Area3D (на картинках выше она обведена синим цветом). Скрипт кнопки понимает, что на ней лежит нужный предмет, и отправляет сигнал менеджеру анимаций. Менеджер анимаций принимает команду и запускает анимацию опускания кнопки и открытия двери.
"
autowrap_mode = 3

[node name="AnimationPlayer" parent="." index="2"]
libraries = {
&"": SubResource("AnimationLibrary_hm6ed")
}
